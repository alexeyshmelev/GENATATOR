  "inference": {
    "device": "cuda",
    "checkpoint_path": "runs/transcript_type_moderngena_base_plain/final_model",
    "batch_size": 1,
    "use_reverse_complement": true,
    "threshold": 0.5,
    "output_tsv": "runs/inference/transcript_type_predictions.tsv",
    "metrics_json": "runs/inference/transcript_type_metrics.json"
  }
