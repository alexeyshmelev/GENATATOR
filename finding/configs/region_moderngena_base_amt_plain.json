{
  "seed": 42,
  "model": {
    "family": "amt",
    "backbone_kind": "moderngena",
    "backbone_path": "AIRI-Institute/moderngena-base",
    "tokenizer_path": "AIRI-Institute/moderngena-base",
    "trust_remote_code": true,
    "checkpoint_path": null,
    "use_unet": false,
    "amt": {
      "amt_repo_id": "irodkin/armt-neox-tiny",
      "num_mem_tokens": 16,
      "d_mem": 32,
      "segment_size": 128
    },
    "allow_unsafe_torch_load_with_torch_lt_2_6": true
  },
  "train_dataset": {
    "path": "AIRI-Institute/genatator-gene-finding-dataset",
    "split": "train",
    "genomes": [],
    "chromosomes": [],
    "max_nucleotides": 73728,
    "max_tokens": 8192,
    "overlap": 0.5,
    "target_group": "primary"
  },
  "eval_dataset": {
    "path": "AIRI-Institute/genatator-gene-finding-dataset",
    "split": "validation",
    "genomes": [],
    "chromosomes": [],
    "max_nucleotides": 73728,
    "max_tokens": 8192,
    "overlap": 0.5,
    "target_group": "primary"
  },
  "training": {
    "output_dir": "runs/finding_region_moderngena_base_amt_plain",
    "overwrite_output_dir": false,
    "max_steps": 500000,
    "per_device_train_batch_size": 2,
    "per_device_eval_batch_size": 2,
    "gradient_accumulation_steps": 1,
    "learning_rate": 5e-05,
    "weight_decay": 0.0001,
    "warmup_steps": 1000,
    "lr_scheduler_type": "constant_with_warmup",
    "logging_steps": 100,
    "eval_steps": 1000,
    "save_steps": 1000,
    "save_total_limit": 3,
    "load_best_model_at_end": true,
    "metric_for_best_model": "loss",
    "greater_is_better": false,
    "dataloader_num_workers": 16,
    "bf16": true,
    "fp16": false,
    "resume_from_checkpoint": null,
    "save_safetensors": false,
    "logging_interval": 100,
    "eval_interval": 1000,
    "save_interval": 1000
  }
}