{
  "seed": 42,
  "model": {
    "family": "amt",
    "backbone_kind": "gena",
    "backbone_path": "AIRI-Institute/gena-lm-bert-base-lastln-t2t",
    "tokenizer_path": "AIRI-Institute/gena-lm-bert-base-lastln-t2t",
    "trust_remote_code": true,
    "checkpoint_path": null,
    "allow_unsafe_torch_load_with_torch_lt_2_6": true,
    "use_unet": false,
    "amt": {
      "amt_repo_id": "irodkin/armt-neox-tiny",
      "num_mem_tokens": 10,
      "d_mem": 32,
      "segment_size": 502
    }
  },
  "train_dataset": {
    "path": "AIRI-Institute/genatator-gene-finding-dataset",
    "split": "train",
    "genomes": [],
    "chromosomes": [],
    "overlap": 0.5,
    "target_group": "primary",
    "max_bpe_tokens": 4096,
    "average_bpe_token_length": 9.0
  },
  "eval_dataset": {
    "path": "AIRI-Institute/genatator-gene-finding-dataset",
    "split": "validation",
    "genomes": [],
    "chromosomes": [],
    "overlap": 0.5,
    "target_group": "primary",
    "max_bpe_tokens": 4096,
    "average_bpe_token_length": 9.0
  },
  "true_gff": null,
  "training": {
    "output_dir": "runs/finding_region_gena_base_amt_plain",
    "custom_prefix": "",
    "overwrite_output_dir": false,
    "max_steps": 500000,
    "per_device_train_batch_size": 1,
    "per_device_eval_batch_size": 1,
    "gradient_accumulation_steps": 1,
    "learning_rate": 5e-05,
    "weight_decay": 0.0001,
    "warmup_steps": 1000,
    "lr_scheduler_type": "constant_with_warmup",
    "logging_steps": 100,
    "eval_steps": 1000,
    "save_steps": 1000,
    "save_total_limit": 3,
    "load_best_model_at_end": true,
    "metric_for_best_model": "loss",
    "greater_is_better": false,
    "dataloader_num_workers": 0,
    "bf16": true,
    "fp16": false,
    "resume_from_checkpoint": null,
    "save_safetensors": false,
    "logging_interval": 100,
    "eval_accumulation_steps": 1,
    "patience": 100
  },
  "task": "finding_region"
}
