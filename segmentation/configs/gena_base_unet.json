{
  "seed": 42,
  "model": {
    "family": "unet",
    "backbone_kind": "gena",
    "backbone_path": "AIRI-Institute/gena-lm-bert-base-lastln-t2t",
    "tokenizer_path": "AIRI-Institute/gena-lm-bert-base-lastln-t2t",
    "trust_remote_code": true,
    "checkpoint_path": null,
    "nucleotide_tokenizer_path": "AIRI-Institute/gena-lm-bert-base-lastln-t2t",
    "nucleotide_vocab_size": null,
    "unet_cycles": 1,
    "allow_unsafe_torch_load_with_torch_lt_2_6": true
  },
  "train_dataset": {
    "path": "AIRI-Institute/genatator-gene-segmentation-dataset",
    "config_name": "train-human",
    "split": "train",
    "genomes": [],
    "chromosomes": [],
    "max_nucleotides": 250000,
    "max_tokens": 32768,
    "overlap": 0.5,
    "crop_margin": 500,
    "random_crop": true,
    "target_group": "primary",
    "statuses": [
      1
    ],
    "loader": "direct_parquet",
    "parquet_batch_size": 64
  },
  "eval_dataset": {
    "path": "AIRI-Institute/genatator-gene-segmentation-dataset",
    "config_name": "val-human",
    "split": "validation",
    "genomes": [],
    "chromosomes": [],
    "max_nucleotides": 250000,
    "max_tokens": 32768,
    "overlap": 0.5,
    "crop_margin": 500,
    "random_crop": false,
    "target_group": "primary",
    "statuses": [
      1
    ],
    "loader": "direct_parquet",
    "parquet_batch_size": 64
  },
  "training": {
    "output_dir": "runs/segmentation_gena_base_unet",
    "overwrite_output_dir": false,
    "max_steps": 500000,
    "per_device_train_batch_size": 1,
    "per_device_eval_batch_size": 1,
    "gradient_accumulation_steps": 1,
    "learning_rate": 5e-05,
    "weight_decay": 0.0001,
    "warmup_steps": 1000,
    "lr_scheduler_type": "constant_with_warmup",
    "logging_steps": 100,
    "eval_steps": 1000,
    "save_steps": 1000,
    "save_total_limit": 3,
    "load_best_model_at_end": true,
    "metric_for_best_model": "interval_f1_exon",
    "greater_is_better": true,
    "dataloader_num_workers": 16,
    "bf16": true,
    "fp16": false,
    "resume_from_checkpoint": null,
    "save_safetensors": false,
    "logging_interval": 100,
    "eval_interval": 1000,
    "save_interval": 1000,
    "eval_accumulation_steps": 1
  }
}
