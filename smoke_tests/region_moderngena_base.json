{
  "seed": 42,
  "model": {
    "family": "moderngena_token",
    "backbone_path": "AIRI-Institute/moderngena-base",
    "tokenizer_path": "AIRI-Institute/moderngena-base",
    "num_labels": 2,
    "classifier_dropout": 0.0,
    "trust_remote_code": true,
    "backbone_trainable": true,
    "checkpoint_path": ""
  },
  "train_dataset": {
    "path": "smoke_tests/data/finding/train.jsonl",
    "split": "train",
    "genomes": [
      "smoke_genome"
    ],
    "chromosomes": [
      "chrSmoke"
    ],
    "target_group": "combined",
    "max_tokens": 128,
    "max_nucleotides": 512,
    "overlap": 0.5,
    "shuffle_starts": false,
    "max_windows": 4
  },
  "eval_dataset": {
    "path": "smoke_tests/data/finding/validation.jsonl",
    "split": "train",
    "genomes": [
      "smoke_genome"
    ],
    "chromosomes": [
      "chrSmoke"
    ],
    "target_group": "combined",
    "max_tokens": 128,
    "max_nucleotides": 512,
    "overlap": 0.5,
    "max_windows": 2
  },
  "training": {
    "output_dir": "smoke_tests/runs/finding_region",
    "resume_from_checkpoint": "",
    "max_steps": 2,
    "per_device_train_batch_size": 1,
    "per_device_eval_batch_size": 1,
    "gradient_accumulation_steps": 1,
    "learning_rate": 5e-05,
    "weight_decay": 0.0001,
    "warmup_steps": 0,
    "lr_scheduler_type": "constant_with_warmup",
    "logging_steps": 1,
    "eval_steps": 1,
    "save_steps": 1,
    "save_total_limit": 1,
    "load_best_model_at_end": true,
    "metric_for_best_model": "eval_auc_mean",
    "greater_is_better": true,
    "bf16": false,
    "dataloader_num_workers": 0
  }
}